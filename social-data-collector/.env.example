# social-data-collector loads all runtime config from the ROOT .env file.
# This file documents the service-specific vars but is not loaded at runtime.
# Copy values to /Users/kain0208/project/probation-project/.env.

DATABASE_URL=
REDIS_URL=

FACEBOOK_GRAPH_API_VERSION=

YOUTUBE_BASE_URL=

SYNC_FACEBOOK_ENABLED=true
SYNC_YOUTUBE_ENABLED=true
SYNC_DEFAULT_INTERVAL_MINUTES=60
SYNC_MAX_RETRIES=5
SYNC_BACKOFF_INITIAL_SECONDS=60
SYNC_BACKOFF_MAX_SECONDS=3600