# --- Database (used by docker-compose and the app) ---
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=
DATABASE_URL=
DATABASE_POOL_SIZE=10
DATABASE_POOL_RECYCLE_SECONDS=3600

# --- Redis (used by docker-compose and Celery) ---
REDIS_PORT=
REDIS_URL=

# --- Facebook Graph API ---
FACEBOOK_GRAPH_API_VERSION=v25.0
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_APP_ACCESS_TOKEN=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_TEST_PAGE_IDS=
FACEBOOK_TEST_PAGE_ID=

# --- YouTube Data API v3 ---
YOUTUBE_API_KEY=
YOUTUBE_TEST_CHANNEL_IDS=
YOUTUBE_TEST_CHANNEL_ID=
YOUTUBE_UPLOADS_PLAYLIST_ID=
YOUTUBE_BASE_URL=https://www.googleapis.com/youtube/v3

# --- Telegram (used by alert engine, gateway, and mini app) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_APP_URL=
TELEGRAM_BOT_USERNAME=

# --- Data collector sync configuration ---
SYNC_FACEBOOK_ENABLED=true
SYNC_YOUTUBE_ENABLED=true
SYNC_DEFAULT_INTERVAL_MINUTES=60
SYNC_MAX_RETRIES=5
SYNC_BACKOFF_INITIAL_SECONDS=60
SYNC_BACKOFF_MAX_SECONDS=3600
SYNC_ACTIVITY_SAMPLE_SIZE=50

# --- API gateway ---
GATEWAY_HOST=
GATEWAY_PORT=
GATEWAY_WORKERS=
GATEWAY_API_PREFIX=

# --- CORS (used by the API gateway) ---
# Comma-separated list of allowed origins (e.g. ngrok URLs for dev).
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Cache (used by the API gateway) ---
CACHE_SUBJECT_TTL_SECONDS=
CACHE_LIST_TTL_SECONDS=
CACHE_ACTIVITY_TTL_SECONDS=

# --- API key auth (used by the API gateway) ---
# Pepper is a server-side secret mixed into the key hash. Rotate to
# invalidate every issued key.
API_KEY_PEPPER=

# --- Admin endpoints (used by the API gateway) ---
# Static bearer token required by /v1/admin/* endpoints (e.g. key creation).
# Generate one with: openssl rand -hex 32
# If empty, all admin endpoints reject every request.
ADMIN_TOKEN=

# --- Credential encryption (used by gateway admin + collector) ---
# Symmetric key for encrypting stored platform credentials at rest.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# --- JWT auth (used by the API gateway for Telegram mini-app login) ---
# Generate one with: openssl rand -hex 32
JWT_SECRET=

# --- Alert engine ---
ALERT_EVALUATION_INTERVAL_SECONDS=300
ALERT_DEFAULT_COOLDOWN_SECONDS=3600

# --- Runtime ---
LOG_LEVEL=INFO
ENVIRONMENT=development
