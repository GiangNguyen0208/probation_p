# social-api-gateway loads all runtime config from the ROOT .env file.
# This file documents the service-specific vars but is not loaded at runtime.
# Copy values to /Users/kain0208/project/probation-project/.env.

DATABASE_URL=
DATABASE_POOL_SIZE=10
DATABASE_POOL_RECYCLE_SECONDS=3600

REDIS_URL=

GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_WORKERS=1
GATEWAY_API_PREFIX=/v1

CACHE_SUBJECT_TTL_SECONDS=300
CACHE_LIST_TTL_SECONDS=60
CACHE_ACTIVITY_TTL_SECONDS=60

API_KEY_PEPPER=
CREDENTIAL_ENCRYPTION_KEY=
ADMIN_TOKEN=

TELEGRAM_BOT_TOKEN=
TELEGRAM_APP_URL=
TELEGRAM_BOT_USERNAME=

CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

LOG_LEVEL=INFO
ENVIRONMENT=development
