            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 10000,
              "minimum": 1,
              "description": "Max snapshots to return.",
              "default": 1000,
              "title": "Limit"
            },
            "description": "Max snapshots to return."
          },
